// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Medication search cache
model MedicationCache {
  id             String   @id @default(cuid())
  medicationName String
  normalizedName String   // Lowercase for case-insensitive search
  supplier       String   // "laborex" or "ubipharm"
  available      Boolean
  price          Float?
  currency       String?
  deliveryTime   String?
  productUrl     String?
  rawData        String?  // JSON string of additional data
  searchedAt     DateTime @default(now())
  expiresAt      DateTime // Cache expiration time

  @@index([normalizedName, supplier])
  @@index([expiresAt])
}

// Supplier credentials (encrypted in production)
model SupplierCredential {
  id        String   @id @default(cuid())
  supplier  String   @unique // "laborex" or "ubipharm"
  username  String
  password  String   // In production, this should be encrypted
  loginUrl  String
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Search history
model SearchHistory {
  id         String   @id @default(cuid())
  query      String
  results    String   // JSON string of results
  searchedAt DateTime @default(now())

  @@index([searchedAt])
}

// SYCAPAY Merchant Credentials
model SycapayCredential {
  id           String   @id @default(cuid())
  merchantId   String   @unique // Merchant ID provided by SYCAPAY
  apiKey       String   // API Key provided by SYCAPAY
  environment  String   @default("TEST") // TEST or PRODUCTION
  country      String   @default("BJ") // Country code (BJ for Benin)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Payment Transaction
model PaymentTransaction {
  id              String   @id @default(cuid())
  orderId         String   @unique // Unique order number
  transactionId   String?  // SYCAPAY transaction ID
  paiementId      String?  // Operator payment reference
  amount          Float
  currency        String   @default("XOF")
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  statusCode      Int?     // SYCAPAY status code
  statusMessage   String?
  customerPhone   String
  customerName    String?
  customerPName   String?
  operator        String?  // Mobile money operator (MtnBJ, MoovBJ, etc.)
  operatorToken   String?  // Token from authentication phase
  notifyUrl       String?
  metadata        String?  // JSON string for additional data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?

  @@index([orderId])
  @@index([transactionId])
  @@index([status])
  @@index([createdAt])
}

// Order
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique // Unique order number
  items           String   // JSON string of order items
  totalAmount     Float
  currency        String   @default("XOF")
  status          String   @default("PENDING") // PENDING, PAID, CANCELLED, COMPLETED
  paymentMethod   String?  // Mobile money operator
  paymentStatus   String   @default("UNPAID") // UNPAID, PAID, FAILED
  transactionId   String?  // Reference to PaymentTransaction
  customerPhone   String
  customerName    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}
